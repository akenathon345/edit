# VE Edit API — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs

# Clé API Anthropic (obligatoire)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (optionnel — le pipeline tourne sans, mais pas de guidelines client ni de logs)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=eyJ...  # service_role key (pas la publishable key)

# Serveur
PORT=3002

# Répertoire temporaire pour les bundles vidéo extraits
BUNDLE_TMP_DIR=/tmp/ve-edit-bundles
